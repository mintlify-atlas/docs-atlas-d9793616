  "keyFeatures": [
    "XGBoost model with 85.24% AUPRC for fraud detection",
    "Handles highly imbalanced datasets (0.17% fraud rate)",
    "Hyperparameter optimization using Optuna Bayesian search",
    "MLflow experiment tracking and model versioning",
    "FastAPI REST API with single and batch prediction endpoints",
    "Prometheus metrics and Grafana dashboards for monitoring",
    "Docker containerization for deployment",
    "Comprehensive data preprocessing and feature scaling"
  ],
  "publicApiSurface": [
    "POST /api/predict - Single transaction fraud prediction",
    "POST /api/predict/batch - Batch transaction predictions",
    "GET /api/health - Health check endpoint",
    "GET /metrics - Prometheus metrics endpoint",
    "TransactionInput - Input schema with V1-V28 PCA features and Amount",
    "PredictionResponse - Fraud probability and classification response",
    "train_model() - Train XGBoost model with optimized parameters",
    "predict_fraud() - Predict fraud probability for transactions",
    "predict_fraud_class() - Classify transactions as fraud/legitimate"
  ]
